int main() {
    int arr[] = {1, 2, 3, 4};
    int n = 4, k = 3;
    int temp[4];

    for (int i = 0; i < n; i++)
        temp[(i + k) % n] = arr[i];

    for (int i = 0; i < n; i++)
        printf("%d ", temp[i]);

    return 0;
}
